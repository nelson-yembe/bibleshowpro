{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bible Show Pro",
  "version": "1.2.0",
  "identifier": "com.bibleshowpro.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bible Show Pro",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "copyright": "Copyright © 2026 Bible Show Pro",
    "shortDescription": "Church Bible presentation software",
    "longDescription": "Bible Show Pro is a desktop presentation platform for churches — search scripture, build service plans, and project to external displays.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
